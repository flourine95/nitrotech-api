              "color": "black"
            },
            "active": true,
            "images": [
              "https://example.com/img1.jpg"
            ],
            "variants": [
              {
                "id": 4,
                "productId": 2,
                "sku": "SKU-1776254954-A",
                "name": "Size S",
                "price": 100000,
                "attributes": {
                  "size": "S"
                },
                "active": true,
                "createdAt": "2026-04-15T19:09:14.4867529",
                "updatedAt": "2026-04-15T19:09:14.4867529"
              },
              {
                "id": 5,
                "productId": 2,
                "sku": "SKU-1776254954-B",
                "name": "Size M",
                "price": 120000,
                "attributes": {
                  "size": "M"
                },
                "active": true,
                "createdAt": "2026-04-15T19:09:14.4887511",
