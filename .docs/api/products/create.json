    "409_slug_exists": {
      "status": 409,
      "body": {
        "status": 409,
        "code": "PRODUCT_SLUG_EXISTS",
        "message": "Slug already exists"
      }
    },
    "422_validation": {
      "status": 422,
      "body": {
        "status": 422,
        "code": "VALIDATION_ERROR",
