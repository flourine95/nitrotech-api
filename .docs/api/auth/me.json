{
  "endpoint": "GET /api/auth/me",
  "description": "Get current authenticated user profile.",
  "request": {
    "headers": {
      "Authorization": "Bearer <access-token>"
    }
  },
  "responses": {
    "200": {
      "status": 200,
      "body": {
        "data": {
          "id": 1,
          "name": "Test User",
          "email": "test_1775081348@example.com",
          "phone": null,
          "avatar": null,
          "status": "active",
          "provider": "local"
        }
      }
    },
    "401_unauthorized": {
      "status": 401,
      "body": {
        "status": 401,
        "code": "UNAUTHORIZED",
        "message": "Unauthorized"
      }
    }
  }
}