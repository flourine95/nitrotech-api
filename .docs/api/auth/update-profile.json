{
  "endpoint": "PUT /api/auth/profile",
  "description": "Update current user profile. All fields are optional.",
  "request": {
    "headers": {
      "Authorization": "Bearer <access-token>"
    },
    "body": {
      "name": "New Name",
      "phone": "0123456789",
      "avatar": "https://example.com/avatar.png"
    }
  },
  "responses": {
    "200": {
      "status": 200,
      "body": {
        "data": {
          "id": 1,
          "name": "New Name",
          "email": "test_1775081348@example.com",
          "phone": "0123456789",
          "avatar": "https://example.com/avatar.png",
          "status": "active",
          "provider": "local"
        }
      }
    },
    "422_validation": {
      "status": 422,
      "body": {
        "status": 422,
        "code": "VALIDATION_ERROR",
        "message": "Validation failed",
        "errors": {
          "name": "Name must be between 2 and 255 characters"
        }
      }
    }
  }
}