{
  "endpoint": "PATCH /api/categories/bulk/deactivate",
  "description": "Bulk deactivate categories. Set active=false cho tất cả ids.",
  "request": {
    "body": {
      "ids": "number[] (required)"
    }
  },
  "responses": {
    "200_ok": {
      "status": 200,
      "body": {
        "data": {
          "succeeded": 2,
          "failed": 0,
          "failedIds": [],
          "failedReasons": {}
        }
      }
    }
  }
}