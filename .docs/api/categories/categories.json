  "restore": {
    "endpoint": "PATCH /api/categories/{id}/restore",
    "description": "Restore category đã soft delete. Trả 409 nếu slug conflict.",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 200,
        "body": {
          "message": "Category restored successfully"
        }
      },
      "404_not_found": {
        "status": 404,
        "body": {
