          "code": "CATEGORY_NOT_FOUND",
          "message": "Deleted category not found"
        }
      }
    }
  },
  "update": {
    "endpoint": "PUT /api/categories/{id}",
    "description": "Cập nhật category. Validate circular reference khi đổi parentId.",
