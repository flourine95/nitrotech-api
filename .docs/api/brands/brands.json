{
  "bulk-delete": {
    "endpoint": "DELETE /api/brands/bulk",
    "description": "Soft delete nhiều brands cùng lúc. Max 100 ids.",
    "request": {
      "body": {
        "ids": "array<number> (required, max 100)"
      }
    },
    "responses": {
      "200_all_success": {
        "status": 200,
        "body": {
          "data": {
            "succeeded": 2,
            "failed": 0,
            "failedIds": [],
            "failedReasons": {}
          }
        }
      },
      "200_partial_success": {
        "status": 200,
        "body": {
          "data": {
            "succeeded": 1,
            "failed": 2,
            "failedIds": [
              999998,
              999999
            ],
            "failedReasons": {
              "999998": "Brand not found or already deleted",
              "999999": "Brand not found or already deleted"
            }
          }
        }
      },
      "422_validation": {
        "status": 422,
        "body": {
          "status": 422,
          "code": "VALIDATION_ERROR",
          "message": "Validation failed",
          "errors": {
            "ids": "ids must not be empty"
          }
        }
      }
    },
    "notes": [
      "Response có failedReasons: Map<id, reason> cho từng id thất bại",
      "Partial success: succeeded > 0 && failed > 0"
    ]
  },
  "bulk-hard-delete": {
    "endpoint": "DELETE /api/brands/bulk/permanent",
    "description": "Xóa vĩnh viễn nhiều brands. Chỉ cho phép với brands đã soft deleted. Block nếu có products.",
    "request": {
      "body": {
        "ids": "array<number> (required, max 100)"
      }
    },
    "responses": {
      "200_all_success": {
        "status": 200,
        "body": {
          "data": {
            "succeeded": 2,
            "failed": 0,
            "failedIds": [],
            "failedReasons": {}
          }
        }
      },
      "200_partial_success": {
        "status": 200,
        "body": {
          "data": {
            "succeeded": 1,
            "failed": 2,
            "failedIds": [
              999998,
              999999
            ],
            "failedReasons": {
              "999998": "Brand not found or not soft-deleted yet",
              "999999": "Brand not found or not soft-deleted yet"
            }
          }
        }
      },
      "422_validation": {
        "status": 422,
        "body": {
          "status": 422,
          "code": "VALIDATION_ERROR",
          "message": "Validation failed",
          "errors": {
            "ids": "ids must not be empty"
          }
        }
      }
    },
    "notes": [
      "Phải soft delete trước",
      "Block nếu brand có products liên kết (chỉ đếm products chưa xóa)",
      "Response có failedReasons: Map<id, reason> cho từng id thất bại",
      "Reasons: 'Brand still has active products' | 'Brand not found or not deleted'",
      "Partial success: succeeded > 0 && failed > 0"
    ]
  },
  "bulk-restore": {
    "endpoint": "PATCH /api/brands/bulk/restore",
    "description": "Restore nhiều brands đã soft delete. Max 100 ids.",
    "request": {
      "body": {
        "ids": "array<number> (required, max 100)"
      }
    },
    "responses": {
      "200_all_success": {
        "status": 200,
        "body": {
          "data": {
            "succeeded": 2,
            "failed": 0,
            "failedIds": [],
            "failedReasons": {}
          }
        }
      },
      "200_partial_success": {
        "status": 200,
        "body": {
          "data": {
            "succeeded": 1,
            "failed": 2,
            "failedIds": [
              999998,
              999999
            ],
            "failedReasons": {
              "999998": "Brand not found or not deleted",
              "999999": "Brand not found or not deleted"
            }
          }
        }
      },
      "422_validation": {
        "status": 422,
        "body": {
          "status": 422,
          "code": "VALIDATION_ERROR",
          "message": "Validation failed",
          "errors": {
            "ids": "ids must not be empty"
          }
        }
      }
    },
    "notes": [
      "Response có failedReasons: Map<id, reason> cho từng id thất bại",
      "Trả 409 nếu slug conflict khi restore",
      "Partial success: succeeded > 0 && failed > 0"
    ]
  },
  "create": {
    "endpoint": "POST /api/brands",
    "description": "Tạo brand mới. Slug phải unique trong active records.",
    "request": {
      "body": {
        "name": "string (required)",
        "slug": "string (required, unique)",
        "logo": "string (optional, url)",
        "description": "string (optional)",
        "active": "boolean (required)"
      }
    },
    "responses": {
      "201_created": {
        "status": 201,
        "body": {
          "data": {
            "id": 42,
            "name": "Test Brand",
            "slug": "test-brand-1777583371",
            "logo": "https://example.com/logo.png",
            "description": "A test brand",
            "active": true,
            "createdAt": "2026-05-01T04:09:31.5183906",
            "updatedAt": "2026-05-01T04:09:31.5183906"
          },
          "message": "Created successfully"
        }
      },
      "409_slug_exists": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "BRAND_SLUG_EXISTS",
          "message": "Slug already exists"
        }
      },
      "422_validation": {
        "status": 422,
        "body": {
          "status": 422,
          "code": "VALIDATION_ERROR",
          "message": "Validation failed",
          "errors": {
            "name": "Name is required",
            "slug": "Slug is required"
          }
        }
      }
    }
  },
  "delete": {
    "endpoint": "DELETE /api/brands/{id}",
    "description": "Soft delete brand. Brand vẫn còn trong DB, có thể restore.",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 200,
        "body": {
          "message": "Brand deleted successfully"
        }
      },
      "404_not_found": {
        "status": 404,
        "body": {
          "status": 404,
          "code": "BRAND_NOT_FOUND",
          "message": "Brand not found"
        }
      }
    }
  },
