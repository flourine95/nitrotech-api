{
  "endpoint": "DELETE /api/brands/{id}",
  "description": "Soft delete a brand. Deleted brands are excluded from all queries.",
  "request": {
    "path": {
      "id": 2
    }
  },
  "responses": {
    "200": {
      "status": 200,
      "body": {
        "message": "Brand deleted successfully"
      }
    },
    "404_not_found": {
      "status": 404,
      "body": {
        "status": 404,
        "code": "BRAND_NOT_FOUND",
        "message": "Brand not found"
      }
    }
  }
}